<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('../partials/head') %>
    <title>Ticket #<%= venta.id %></title>
    <style>
        @page {
            size: 57mm auto;
            margin: 0;
        }

        body {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            width: 57mm;
            max-width: 57mm;
            margin: 0 auto;
            padding: 8px 5px;           /* Márgenes laterales mínimos */
            line-height: 1.3;
        }

        .ticket {
            text-align: center;
        }

        h3 {
            margin: 5px 0 3px 0;
            font-size: 15px;
        }

        p {
            margin: 3px 0;
        }

        .text-left { text-align: left; }
        .text-right { text-align: right; }

        hr {
            border: 0;
            border-top: 1px dashed #000;
            margin: 8px 0;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
        }

        th, td {
            padding: 2px 0;
        }

        .total {
            font-size: 16px;
            font-weight: bold;
        }

        .footer {
            margin-top: 15px;
            font-size: 12px;
        }

        /* Espacio extra al final para que corte bien el papel */
        .cut-space {
            height: 35px;
        }

        @media print {
            body { 
                margin: 0; 
                padding: 8px 5px; 
            }
            .no-print { display: none; }
        }
    </style>
</head>
<body>
    <div class="ticket">
        <h3>TIENDA JAZMIN</h3>
        <p>Jardin America</p>
        <hr>
        
        <p class="text-left">Fecha: <%= new Date(venta.fecha).toLocaleString('es-AR') %></p>
        <p class="text-left">Pago: <%= venta.metodo_pago %></p>
        <hr>

        <table>
            <thead>
                <tr>
                    <th class="text-left">Producto</th>
                    <th>Cant</th>
                    <th>Precio</th>
                    <th class="text-right">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                <% detalles.forEach(item => { %>
                <tr>
                    <td class="text-left"><%= item.producto_nombre %></td>
                    <td><%= item.cantidad %></td>
                    <td><%= Number(item.precio_unitario).toFixed(0) %></td>
                    <td class="text-right">$<%= Number(item.subtotal).toFixed(0) %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>

        <hr>
        <p class="total text-right">TOTAL: $<%= Number(venta.total).toFixed(0) %></p>
        <hr>
        
        <p class="footer">¡Gracias por su compra!</p>
        <p class="footer">Venta #<%= venta.id %></p>
        
        <!-- Espacio importante para el corte del papel -->
        <div class="cut-space"></div>
    </div>

    <script>
        window.onload = function() {
            window.print();
        }
    </script>
</body>
</html>