<!DOCTYPE html>
<html lang="es">

<%- include('../partials/head') %>

<body class="bg-light">

<div class="d-flex">

    <%- include('../partials/sidebar') %>

    <div class="flex-grow-1">

        <%- include('../partials/navbar') %>

        <div class="container-fluid p-4">

            <h2 class="mb-4">
                Nueva Venta
            </h2>

            <div class="row">

                <!-- IZQUIERDA -->
                <div class="col-md-8">

                    <div class="card shadow-sm mb-4">

                        <div class="card-body">

                            <div class="row">

                                <div class="col-md-6">

                                    <label class="form-label">
                                        Producto
                                    </label>

                                    <select
                                        id="productoSelect"
                                        class="form-select"
                                    >

                                        <option value="">
                                            Seleccionar producto
                                        </option>

                                    </select>

                                      <div class="mt-3">

                                    <button
                                        class="btn btn-outline-secondary btn-sm"
                                        id="toggleManualBtn"
                                    >
                                        Producto manual
                                    </button>

                                </div>
                                <div
                                    id="manualProductoContainer"
                                    class="row mt-3"
                                    style="display: none;"
                                >

                                    <div class="col-md-6">

                                        <label class="form-label">
                                            Nombre producto
                                        </label>

                                        <input
                                            type="text"
                                            id="manualNombre"
                                            class="form-control"
                                        >

                                    </div>

                                    <div class="col-md-3">

                                        <label class="form-label">
                                            Precio
                                        </label>

                                        <input
                                            type="number"
                                            id="manualPrecio"
                                            class="form-control"
                                        >

                                    </div>

                                </div>

                                </div>

                                <div class="col-md-3">

                                    <label class="form-label">
                                        Cantidad
                                    </label>

                                    <input
                                        type="number"
                                        id="cantidadInput"
                                        class="form-control"
                                        value="1"
                                        min="1"
                                    >

                                </div>

                                <div class="col-md-3 d-flex align-items-end">

                                    <button
                                        class="btn btn-dark w-100"
                                        id="agregarBtn"
                                    >
                                        Agregar
                                    </button>

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="card shadow-sm">

                        <div class="card-body">

                            <table class="table">

                                <thead>

                                    <tr>

                                        <th>
                                            Producto
                                        </th>

                                        <th>
                                            Cantidad
                                        </th>

                                        <th>
                                            Precio
                                        </th>

                                        <th>
                                            Subtotal
                                        </th>

                                        <th>
                                            Acción
                                        </th>

                                    </tr>

                                </thead>

                                <tbody id="carritoBody">

                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

                <!-- DERECHA -->
                <div class="col-md-4">

                    <div class="card shadow-sm">

                        <div class="card-body">

                            <h4 class="mb-4">
                                Resumen
                            </h4>

                            <div class="d-flex justify-content-between mb-3">

                                <span>
                                    Total:
                                </span>

                                <strong id="totalVenta">
                                    $0
                                </strong>

                            </div>

                            <div class="mb-3">

                                <label class="form-label">
                                    Método de pago
                                </label>

                                <select class="form-select"
                                 id="metodoPago">

                                    <option>
                                        EFECTIVO
                                    </option>

                                    <option>
                                        TRANSFERENCIA
                                    </option>

                                    <option>
                                        TARJETA
                                    </option>

                                </select>                                  

                                

                            </div>

                            <button
                            class="btn btn-success w-100"
                            id="finalizarVentaBtn"
                        >
                            Finalizar Venta
                        </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<script>

let productos = [];

let carrito = [];
let modoManual = false;

async function cargarProductos() {

    const response = await fetch("/productos");

    productos = await response.json();

    const select = document.getElementById("productoSelect");

    productos.forEach(producto => {

        const option = document.createElement("option");

        option.value = producto.id;

        option.textContent =
            `${producto.nombre} - $${producto.precio}`;

        select.appendChild(option);

    });

}

function renderCarrito() {

    const body = document.getElementById("carritoBody");

    body.innerHTML = "";

    let total = 0;

    carrito.forEach((item, index) => {

        const subtotal =
            item.precio * item.cantidad;

        total += subtotal;

        body.innerHTML += `
            <tr>

                <td>
                    ${item.nombre}
                </td>

                <td>
                    ${item.cantidad}
                </td>

                <td>
                    $${item.precio}
                </td>

                <td>
                    $${subtotal}
                </td>

                <td>

                    <button
                        class="btn btn-danger btn-sm"
                        onclick="eliminarProducto(${index})"
                    >
                        X
                    </button>

                </td>

            </tr>
        `;

    });

    document.getElementById("totalVenta")
        .textContent = `$${total}`;

}

function eliminarProducto(index) {

    carrito.splice(index, 1);

    renderCarrito();

}


document
.getElementById("toggleManualBtn")
.addEventListener("click", () => {

    modoManual = !modoManual;

    const container =
        document.getElementById(
            "manualProductoContainer"
        );

    container.style.display =
        modoManual
            ? "flex"
            : "none";

});

document
.getElementById("agregarBtn")
.addEventListener("click", () => {

    const cantidad =
        parseInt(
            document.getElementById("cantidadInput").value
        );

    if (modoManual) {

        const nombre =
            document.getElementById("manualNombre").value;

        const precio =
            parseFloat(
                document.getElementById("manualPrecio").value
            );

        if (!nombre || !precio) {

            alert("Completar producto manual");

            return;

        }

        carrito.push({

            id: null,

            nombre,

            precio,

            cantidad

        });

    } else {

        const productoId =
            document.getElementById("productoSelect").value;

        if (!productoId) {

            alert("Seleccionar producto");

            return;

        }

        const producto =
            productos.find(
                p => p.id == productoId
            );

        carrito.push({

            id: producto.id,

            nombre: producto.nombre,

            precio: parseFloat(producto.precio),

            cantidad

        });

    }

    renderCarrito();

});

document
.getElementById("finalizarVentaBtn")
.addEventListener("click", async () => {

    if (carrito.length === 0) {

        alert("Carrito vacío");

        return;

    }

    const metodo_pago =
        document.getElementById("metodoPago").value

    try {

        const response = await fetch(
            "/api/ventas",
            {

                method: "POST",

                headers: {
                    "Content-Type": "application/json"
                },

                body: JSON.stringify({

                    carrito,
                    metodo_pago

                })

            }
        );

        const data =
            await response.json();

        alert(
            "Venta guardada correctamente"
        );

        carrito = [];

        renderCarrito();

        console.log(data);

    } catch (error) {

        console.log(error);

        alert("Error guardando venta");

    }

});


cargarProductos();

</script>

</body>

</html>