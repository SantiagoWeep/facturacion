<!DOCTYPE html>
<html lang="es">
<%- include('../partials/head') %>
<body class="bg-light">
<div class="d-flex">
    <%- include('../partials/sidebar') %>
    <div class="flex-grow-1">
        <%- include('../partials/navbar') %>

        <div class="container-fluid p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Productos</h2>
                <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modalProducto">
                    <i class="bi bi-plus-lg"></i> Nuevo Producto
                </button>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Nombre</th>
                                <th>Categoría</th>
                                <th>Código</th>
                                <th class="text-end">Precio</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% productos.forEach(producto => { %>
                            <tr>
                                <td><%= producto.nombre %></td>
                                <td><span class="badge bg-secondary"><%= producto.categoria || 'Sin categoría' %></span></td>
                                <td><%= producto.codigo_barras || '-' %></td>
                                <td class="text-end fw-bold">$<%= parseFloat(producto.precio).toFixed(2) %></td>
                                <td class="text-center">
                                    <button class="btn btn-danger btn-sm" 
                                            onclick="eliminarProducto(<%= producto.id %>)">
                                        Eliminar
                                    </button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Nuevo Producto -->
<div class="modal fade" id="modalProducto" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Nuevo Producto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="formProducto" action="/admin/productos" method="POST">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre del Producto</label>
                        <input type="text" name="nombre" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Categoría</label>
                        <input type="text" name="categoria" class="form-control" placeholder="Ej: Ropa, Accesorios, Calzado" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Precio</label>
                        <input type="number" name="precio" class="form-control" step="0.01" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Código de Barras (opcional)</label>
                        <input type="text" name="codigo_barras" class="form-control">
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Guardar Producto</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function eliminarProducto(id) {
    if (confirm("¿Estás seguro de eliminar este producto?")) {
        fetch(`/admin/productos/${id}`, { 
            method: 'DELETE' 
        })
        .then(() => location.reload());
    }
}

// Opcional: Cerrar modal después de enviar (mejora UX)
document.getElementById('formProducto').addEventListener('submit', function() {
    // El redirect lo maneja el servidor
});
</script>
</body>
</html>